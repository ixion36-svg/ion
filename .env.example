# =============================================================================
# ION Environment Configuration
# Intelligent Operating Network
# =============================================================================
# Copy this file to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Image Version
# -----------------------------------------------------------------------------
# Pin to a specific release (e.g. 0.8.0). Defaults to "latest".
# ION_VERSION=0.8.0

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
ION_HOST=0.0.0.0
ION_PORT=8000

# Data directory inside container (usually leave as default)
ION_DATA_DIR=/data

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Set to true when using HTTPS or behind a reverse proxy with SSL
ION_COOKIE_SECURE=false

# Debug mode - enables API documentation at /docs and /openapi.json
# IMPORTANT: Set to false in production (default)
ION_DEBUG_MODE=false

# Initial admin password (only used on first run when database is created)
# IMPORTANT: Change this before first deployment!
ION_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# TLS / Certificates
# -----------------------------------------------------------------------------
# CA bundle for verifying outbound connections to services with internal CA certs
# Point this at your CA certificate file (.pem or .crt)
#ION_CA_BUNDLE=/path/to/ca-bundle.crt

# Serve ION over HTTPS directly (no reverse proxy needed)
# Both cert and key must be PEM format
#ION_SSL_CERT=/path/to/server.crt
#ION_SSL_KEY=/path/to/server.key

# -----------------------------------------------------------------------------
# OIDC / Keycloak Authentication (Recommended for production)
# -----------------------------------------------------------------------------
# Users are managed in Keycloak — ION creates local records on first login.
# Skills, team coverage, etc. populate as users complete self-assessments.
ION_OIDC_ENABLED=true
ION_OIDC_KEYCLOAK_URL=
ION_OIDC_REALM=
ION_OIDC_CLIENT_ID=
ION_OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitLab Integration (Optional)
# -----------------------------------------------------------------------------
ION_GITLAB_ENABLED=true
ION_GITLAB_URL=
ION_GITLAB_TOKEN=
ION_GITLAB_PROJECT_ID=

# -----------------------------------------------------------------------------
# OpenCTI Integration (Optional)
# -----------------------------------------------------------------------------
ION_OPENCTI_ENABLED=true
ION_OPENCTI_URL=
ION_OPENCTI_TOKEN=

# -----------------------------------------------------------------------------
# Elasticsearch Integration (Optional)
# -----------------------------------------------------------------------------
ION_ELASTICSEARCH_ENABLED=true
ION_ELASTICSEARCH_URL=
# Use either username/password OR api_key (not both)
ION_ELASTICSEARCH_USERNAME=
ION_ELASTICSEARCH_PASSWORD=
ION_ELASTICSEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Kibana Cases Integration (Optional)
# -----------------------------------------------------------------------------
ION_KIBANA_CASES_ENABLED=true
ION_KIBANA_URL=
ION_KIBANA_USERNAME=
ION_KIBANA_PASSWORD=

# -----------------------------------------------------------------------------
# Ollama AI Integration (Optional)
# -----------------------------------------------------------------------------
# Enable AI assistant in chat
ION_OLLAMA_ENABLED=true
# URL for Ollama service
# Local:       http://localhost:11434
# Docker:      http://ollama:11434
# Remote/Air-gapped: http://<remote-ip>:11434
ION_OLLAMA_URL=http://localhost:11434
# Default model - options: qwen2.5:0.5b (testing), qwen2.5:7b (default), qwen2.5-coder:7b (code analysis)
ION_OLLAMA_MODEL=qwen2.5:7b
# Request timeout in seconds
ION_OLLAMA_TIMEOUT=120

# Memory limit for Ollama container (increase for larger models)
OLLAMA_MEMORY=8G

# Note: Ollama port is NOT exposed externally by default for security.
# All AI interactions go through ION's authenticated chat interface.
# To enable direct API access (for debugging), uncomment ports in docker-compose.yml

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
ION_LOG_LEVEL=INFO

# Output format: JSON (true) or plain text (false)
# ION_LOG_JSON=true

# Use ECS (Elastic Common Schema) format — recommended when shipping to ES
# ION_LOG_ECS=true

# Write logs to a file (rotating, 50MB x 5 backups)
# ION_LOG_FILE=/data/logs/ion.log

# Ship logs directly to Elasticsearch (uses the same ES credentials above)
# ION_ES_LOG_URL=http://your-es-host:9200
# ION_ES_LOG_INDEX=ion-logs

# Send logs to a remote syslog server (UDP or TCP)
# ION_SYSLOG_URL=udp://syslog-host:514
# ION_SYSLOG_URL=tcp://syslog-host:514
# ION_SYSLOG_FACILITY=local0

# Service metadata (embedded in ECS log records)
# ION_SERVICE_NAME=ion
# ION_ENVIRONMENT=production
