# =============================================================================
# IXION Environment Configuration
# Intelligence eXchange & Integration Operations Network
# =============================================================================
# Copy this file to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Image Version
# -----------------------------------------------------------------------------
# Pin to a specific release (e.g. 0.8.0). Defaults to "latest".
# IXION_VERSION=0.8.0

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
IXION_HOST=0.0.0.0
IXION_PORT=8000

# Data directory inside container (usually leave as default)
IXION_DATA_DIR=/data

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Set to true when using HTTPS or behind a reverse proxy with SSL
IXION_COOKIE_SECURE=false

# Debug mode - enables API documentation at /docs and /openapi.json
# IMPORTANT: Set to false in production (default)
IXION_DEBUG_MODE=false

# Initial admin password (only used on first run when database is created)
# IMPORTANT: Change this before first deployment!
IXION_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# OIDC / Keycloak Authentication (Recommended for production)
# -----------------------------------------------------------------------------
# Users are managed in Keycloak — IXION creates local records on first login.
# Skills, team coverage, etc. populate as users complete self-assessments.
IXION_OIDC_ENABLED=false
IXION_OIDC_KEYCLOAK_URL=
IXION_OIDC_REALM=
IXION_OIDC_CLIENT_ID=
IXION_OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitLab Integration (Optional)
# -----------------------------------------------------------------------------
IXION_GITLAB_ENABLED=false
IXION_GITLAB_URL=
IXION_GITLAB_TOKEN=
IXION_GITLAB_PROJECT_ID=

# -----------------------------------------------------------------------------
# OpenCTI Integration (Optional)
# -----------------------------------------------------------------------------
IXION_OPENCTI_ENABLED=false
IXION_OPENCTI_URL=
IXION_OPENCTI_TOKEN=

# -----------------------------------------------------------------------------
# Elasticsearch Integration (Optional)
# -----------------------------------------------------------------------------
IXION_ELASTICSEARCH_ENABLED=false
IXION_ELASTICSEARCH_URL=
# Use either username/password OR api_key (not both)
IXION_ELASTICSEARCH_USERNAME=
IXION_ELASTICSEARCH_PASSWORD=
IXION_ELASTICSEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Kibana Cases Integration (Optional)
# -----------------------------------------------------------------------------
IXION_KIBANA_CASES_ENABLED=false
IXION_KIBANA_URL=
IXION_KIBANA_USERNAME=
IXION_KIBANA_PASSWORD=

# -----------------------------------------------------------------------------
# Ollama AI Integration (Optional)
# -----------------------------------------------------------------------------
# Enable AI assistant in chat
IXION_OLLAMA_ENABLED=false
# URL for Ollama service (use http://ollama:11434 in Docker)
IXION_OLLAMA_URL=http://localhost:11434
# Default model - options: qwen2.5:0.5b (testing), qwen2.5-coder:7b (production)
IXION_OLLAMA_MODEL=qwen2.5:0.5b
# Request timeout in seconds
IXION_OLLAMA_TIMEOUT=120

# Memory limit for Ollama container (increase for larger models)
OLLAMA_MEMORY=8G

# Note: Ollama port is NOT exposed externally by default for security.
# All AI interactions go through IXION's authenticated chat interface.
# To enable direct API access (for debugging), uncomment ports in docker-compose.yml

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
IXION_LOG_LEVEL=INFO

# Output format: JSON (true) or plain text (false)
# IXION_LOG_JSON=true

# Use ECS (Elastic Common Schema) format — recommended when shipping to ES
# IXION_LOG_ECS=true

# Write logs to a file (rotating, 50MB x 5 backups)
# IXION_LOG_FILE=/data/logs/ixion.log

# Ship logs directly to Elasticsearch (uses the same ES credentials above)
# IXION_ES_LOG_URL=http://your-es-host:9200
# IXION_ES_LOG_INDEX=ixion-logs

# Send logs to a remote syslog server (UDP or TCP)
# IXION_SYSLOG_URL=udp://syslog-host:514
# IXION_SYSLOG_URL=tcp://syslog-host:514
# IXION_SYSLOG_FACILITY=local0

# Service metadata (embedded in ECS log records)
# IXION_SERVICE_NAME=ixion
# IXION_ENVIRONMENT=production
