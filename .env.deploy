# =============================================================================
# ION Deployment Configuration — Siloed / Air-Gapped Environment
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All ION_* variables are read by the ION container at startup.
# =============================================================================

# --- Server ---
ION_HOST=0.0.0.0
ION_PORT=8000
ION_ADMIN_PASSWORD=admin2025
ION_COOKIE_SECURE=false
ION_DEBUG_MODE=false
ION_FRESH_DB=true

# --- Database (PostgreSQL — provided by docker-compose) ---
# No need to change this unless using an external PostgreSQL
# The hostname 'postgres' is the docker-compose service name
ION_DATABASE_URL=postgresql://ion:ion2025@postgres:5432/ion

# --- Elasticsearch ---
# Replace IP with your ES server address
ION_ELASTICSEARCH_ENABLED=true
ION_ELASTICSEARCH_URL=http://REPLACE_WITH_ES_IP:9200
ION_ELASTICSEARCH_USERNAME=elastic
ION_ELASTICSEARCH_PASSWORD=REPLACE_WITH_ES_PASSWORD

# --- Kibana Cases ---
ION_KIBANA_CASES_ENABLED=true
ION_KIBANA_URL=http://REPLACE_WITH_KIBANA_IP:5601
ION_KIBANA_USERNAME=elastic
ION_KIBANA_PASSWORD=REPLACE_WITH_KIBANA_PASSWORD

# --- TIDE (Detection Engineering) ---
ION_TIDE_ENABLED=true
ION_TIDE_URL=https://REPLACE_WITH_TIDE_IP
ION_TIDE_API_KEY=REPLACE_WITH_TIDE_API_KEY
ION_TIDE_VERIFY_SSL=false
ION_TIDE_SPACE=default                                    # Kibana space where rules live (default, production, etc.)

# --- OpenCTI (Threat Intelligence) ---
ION_OPENCTI_ENABLED=true
ION_OPENCTI_URL=http://REPLACE_WITH_OPENCTI_IP:8080
ION_OPENCTI_TOKEN=REPLACE_WITH_OPENCTI_TOKEN
ION_OPENCTI_VERIFY_SSL=false

# --- Ollama AI (Optional) ---
# Point to your Ollama server IP (NOT 127.0.0.1 — that means the container itself)
ION_OLLAMA_ENABLED=false
#ION_OLLAMA_URL=http://REPLACE_WITH_OLLAMA_IP:11434
#ION_OLLAMA_MODEL=llama3.2:latest
#ION_OLLAMA_TIMEOUT=120

# --- TLS / Certificates (Optional) ---
# Uncomment and set path to your internal CA cert if using self-signed certs
#ION_CA_BUNDLE=/etc/ipa/ca.crt
