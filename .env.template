# =============================================================================
# ION Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# All ION_* variables are read by the ION container via env_file in
# docker-compose.yml. Variables prefixed with ION_DB_ or ION_CPUS etc.
# are used by docker-compose.yml itself for resource limits.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────
ION_HOST=0.0.0.0
ION_PORT=8000
ION_ADMIN_PASSWORD=admin2025
# External URL for OIDC redirect URIs (must match Keycloak Valid Redirect URIs)
ION_BASE_URL=https://ion.guardedglass.internal
ION_DATA_DIR=/data
ION_COOKIE_SECURE=true
ION_DEBUG_MODE=false

# ── Database (used by docker-compose for the postgres container) ──────────
ION_DB_PASSWORD=ion2025
# ION_DB_CPUS=4
# ION_DB_MEMORY=4G

# ── ION container resources ───────────────────────────────────────────────
# ION_CPUS=6
# ION_MEMORY=6G
ION_WORKERS=4

# ── TLS / Certificates ───────────────────────────────────────────────────
# Internal CA bundle for verifying outbound connections to ES, Kibana,
# Keycloak, TIDE, Arkime, OpenCTI, etc. Mount the cert via compose volume.
# ION_CA_BUNDLE=/etc/ssl/certs/custom-ca.pem
# Serve ION itself over HTTPS (cert + key in PEM format):
# ION_SSL_CERT=/path/to/server.crt
# ION_SSL_KEY=/path/to/server.key

# ── Elasticsearch ─────────────────────────────────────────────────────────
ION_ELASTICSEARCH_ENABLED=true
ION_ELASTICSEARCH_URL=https://elasticsearch.guardedglass.internal:9200
ION_ELASTICSEARCH_USERNAME=elastic
ION_ELASTICSEARCH_PASSWORD=changeme
# ION_ELASTICSEARCH_VERIFY_SSL=false
# ION_ES_ALERT_INDEX=.alerts-security.alerts-*,alerts-*

# ── Kibana Cases ──────────────────────────────────────────────────────────
ION_KIBANA_CASES_ENABLED=true
ION_KIBANA_URL=https://kibana.guardedglass.internal:5601
ION_KIBANA_USERNAME=elastic
ION_KIBANA_PASSWORD=changeme
ION_KIBANA_SPACE_ID=default
# ION_KIBANA_VERIFY_SSL=false

# ── OIDC / Keycloak SSO ──────────────────────────────────────────────────
ION_OIDC_ENABLED=true
ION_OIDC_KEYCLOAK_URL=https://keycloak.guardedglass.internal
ION_OIDC_REALM=soc
ION_OIDC_CLIENT_ID=ion
ION_OIDC_CLIENT_SECRET=changeme
ION_OIDC_AUTO_CREATE_USERS=true
ION_OIDC_VERIFY_SSL=false
# Role mapping: Keycloak realm role → ION role (JSON)
# ION_OIDC_ROLE_MAPPING={"soc-analyst":"analyst","soc-engineer":"engineering","soc-lead":"lead","admin":"admin"}

# ── Ollama AI (LLM for chat, briefings, training narratives) ─────────────
ION_OLLAMA_ENABLED=true
ION_OLLAMA_URL=http://ollama-host.guardedglass.internal:11434
ION_OLLAMA_MODEL=qwen2.5:3b
ION_OLLAMA_TIMEOUT=120

# ── OpenCTI (threat intel enrichment) ─────────────────────────────────────
ION_OPENCTI_ENABLED=true
ION_OPENCTI_URL=https://opencti.guardedglass.internal:8080
ION_OPENCTI_TOKEN=changeme
ION_OPENCTI_VERIFY_SSL=false

# ── TIDE (Threat Informed Detection Engineering) ──────────────────────────
ION_TIDE_ENABLED=true
ION_TIDE_URL=https://tide.guardedglass.internal
ION_TIDE_API_KEY=changeme
ION_TIDE_VERIFY_SSL=false
ION_TIDE_SPACE=default
# TIDE 4.x multi-tenant: set if your API key has access to multiple tenants
# ION_TIDE_CLIENT_ID=

# ── Arkime (PCAP analysis) ────────────────────────────────────────────────
ION_ARKIME_ENABLED=true
ION_ARKIME_URL=https://viewer.guardedglass.internal
# Auth: Keycloak client_credentials (preferred) or basic auth fallback
ION_ARKIME_KEYCLOAK_ISSUER=https://keycloak.guardedglass.internal/realms/soc
ION_ARKIME_KEYCLOAK_CLIENT_ID=arkime
ION_ARKIME_KEYCLOAK_CLIENT_SECRET=changeme
# ION_ARKIME_USERNAME=
# ION_ARKIME_PASSWORD=
ION_ARKIME_VERIFY_SSL=false

# ── DFIR-IRIS (incident response escalation) ──────────────────────────────
# ION_DFIR_IRIS_ENABLED=false
# ION_DFIR_IRIS_URL=https://iris.guardedglass.internal
# ION_DFIR_IRIS_API_KEY=changeme
# ION_DFIR_IRIS_VERIFY_SSL=false

# ── GitLab (issue tracking) ──────────────────────────────────────────────
# ION_GITLAB_ENABLED=false
# ION_GITLAB_URL=https://gitlab.guardedglass.internal
# ION_GITLAB_TOKEN=changeme
# ION_GITLAB_PROJECT_ID=1
# ION_GITLAB_VERIFY_SSL=false

# ── AbuseIPDB ─────────────────────────────────────────────────────────────
# ION_ABUSEIPDB_ENABLED=false
# ION_ABUSEIPDB_API_KEY=changeme

# ── Network Mapper (CMDB from Elasticsearch) ─────────────────────────────
# ION_NETMAP_INTERVAL_S=120
# ION_NETMAP_LOOKBACK_MIN=10
# ION_NETMAP_INDEX=logs-*
